<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="76dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <View
        android:id="@+id/category_color"
        android:layout_width="8dp"
        android:layout_height="44dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/category_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/category_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/category_move_up"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="4dp"
        android:minWidth="40dp"
        android:minHeight="40dp"
        android:rotation="180"
        android:contentDescription="@string/category_move_up"
        app:backgroundTint="@color/surface_variant"
        app:cornerRadius="20dp"
        app:icon="@drawable/ic_expand_more"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="18dp"
        app:iconTint="@color/brand_primary"
        app:strokeColor="@color/brand_primary"
        app:strokeWidth="1dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/category_move_down"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:minWidth="40dp"
        android:minHeight="40dp"
        android:contentDescription="@string/category_move_down"
        app:backgroundTint="@color/surface_variant"
        app:cornerRadius="20dp"
        app:icon="@drawable/ic_expand_more"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="18dp"
        app:iconTint="@color/brand_primary"
        app:strokeColor="@color/brand_primary"
        app:strokeWidth="1dp" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/category_active_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp" />
</LinearLayout>
